<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>マイページ ─ 教採ナビ</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body {
  font-family: 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif;
  background: #f0f2f5;
  color: #333;
  line-height: 1.8;
  min-height: 100vh;
}
header {
  background: linear-gradient(135deg, #0c2461, #1e3799);
  color: #fff;
  padding: 22px 20px;
  text-align: center;
  box-shadow: 0 2px 8px rgba(0,0,0,.15);
}
header h1 {
  font-size: 1.6em;
  letter-spacing: .04em;
  font-weight: bold;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  text-shadow: 0 2px 4px rgba(0,0,0,.25);
}
header h1 .title-icon { font-size: 1.1em; filter: drop-shadow(0 2px 3px rgba(0,0,0,.35)); }
.header-back { margin-top: 12px; }
.header-back a {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 8px 18px;
  background: linear-gradient(135deg, #0c2461 0%, #1e3799 45%, #0a3d62 100%);
  color: #fff; border: 1px solid #0c2461; border-radius: 7px;
  text-decoration: none; font-size: .9em; font-weight: bold;
}
.header-back a:hover { background: linear-gradient(135deg, #061a4a 0%, #142b75 45%, #062a44 100%); }

.container { max-width: 620px; margin: 0 auto; padding: 26px 16px 60px; }
.greeting {
  text-align: center; font-size: 1.05em; color: #1e3799; font-weight: bold;
  margin-bottom: 16px; min-height: 1.4em;
}

.card {
  background: #fff; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,.08);
  padding: 24px 24px; margin-bottom: 18px;
}
.card h2 {
  font-size: 1.05em; color: #1e3799; margin-bottom: 14px;
  padding-bottom: 10px; border-bottom: 2px solid #dfe4f5;
  display: flex; align-items: center; gap: 8px;
}
.note { font-size: .8em; color: #888; line-height: 1.7; margin: -4px 0 16px; }

/* タブ（ログイン / 新規登録） */
.auth-tabs { display: flex; gap: 8px; margin-bottom: 18px; }
.auth-tab {
  flex: 1; padding: 10px; border: 2px solid #1e3799; background: #fff;
  color: #1e3799; border-radius: 8px; font-weight: bold; cursor: pointer;
  font-family: inherit; font-size: .95em;
}
.auth-tab.active { background: linear-gradient(135deg, #1e3799, #3a7bd5); color: #fff; }

.field { margin-bottom: 15px; }
.field label { display: block; font-size: .9em; font-weight: bold; color: #555; margin-bottom: 6px; }
.field input, .field select {
  width: 100%; padding: 11px 12px; border: 1px solid #ccc; border-radius: 7px;
  font-size: 1em; font-family: inherit; background: #fff; color: #333;
}
.field input:focus, .field select:focus {
  outline: none; border-color: #3a7bd5; box-shadow: 0 0 0 2px rgba(58,123,213,.2);
}
.field .hint { font-size: .76em; color: #999; margin-top: 4px; }
.field-readonly input { background: #f3f5fa; color: #777; }

.btn-row { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 6px; }
.btn {
  padding: 11px 24px; border: none; border-radius: 7px; font-size: .95em;
  font-weight: bold; cursor: pointer; font-family: inherit;
}
.btn:hover { opacity: .92; }
.btn-save { background: linear-gradient(135deg, #1e3799, #3a7bd5); color: #fff; }
.btn-sub { background: #eef1f8; color: #1e3799; }
.btn-clear { background: #eee; color: #555; }
.btn-danger { background: #fdecea; color: #c0392b; }
.btn-block { width: 100%; }

.err { color: #c0392b; font-size: .85em; margin-top: 8px; min-height: 1em; }

/* 成績ダッシュボード */
.summary-row { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 16px; }
.summary-box {
  flex: 1; min-width: 120px; background: #f5f8ff; border: 1px solid #dfe4f5;
  border-radius: 10px; padding: 12px 14px; text-align: center;
}
.summary-box .lbl { font-size: .78em; color: #777; }
.summary-box .num { font-size: 1.5em; font-weight: bold; color: #1e3799; }
.summary-box .num small { font-size: .5em; color: #888; font-weight: normal; }

.sub-title { font-size: .9em; font-weight: bold; color: #34495e; margin: 16px 0 8px; }
.stat-table { width: 100%; border-collapse: collapse; font-size: .9em; }
.stat-table th, .stat-table td {
  padding: 8px 10px; border-bottom: 1px solid #eef2f6; text-align: left;
}
.stat-table th { background: #f5f8fa; color: #555; font-size: .85em; }
.stat-table td.num, .stat-table th.num { text-align: right; white-space: nowrap; }
.bar-wrap { background: #eef2f6; border-radius: 6px; height: 8px; overflow: hidden; margin-top: 4px; }
.bar { height: 100%; background: linear-gradient(90deg, #3a7bd5, #1e3799); }
.rate-good { color: #1e7e34; font-weight: bold; }
.rate-mid { color: #b8860b; font-weight: bold; }
.rate-low { color: #c0392b; font-weight: bold; }
.empty-stat { color: #999; font-size: .88em; padding: 14px 4px; text-align: center; }

/* 学習時間 */
.study-tabs { display: flex; gap: 8px; margin: 8px 0 12px; }
.study-tab {
  flex: 1; padding: 8px; border: 2px solid #1e3799; background: #fff; color: #1e3799;
  border-radius: 8px; font-weight: bold; cursor: pointer; font-family: inherit; font-size: .9em;
}
.study-tab.active { background: linear-gradient(135deg, #1e3799, #3a7bd5); color: #fff; }
#studyChart { overflow-x: auto; }

.toast {
  position: fixed; bottom: 30px; left: 50%;
  transform: translateX(-50%) translateY(80px); background: #333; color: #fff;
  padding: 12px 28px; border-radius: 8px; font-size: .9em; opacity: 0;
  transition: all .3s; z-index: 999; pointer-events: none;
}
.toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }

@media (max-width: 600px) { header h1 { font-size: 1.2em; } }
</style>
</head>
<body>
<header>
  <h1><span class="title-icon">👤</span>マイページ</h1>
  <div class="header-back"><a href="index.html">🏠 教採ナビ トップへ</a></div>
</header>

<div class="container">
  <div class="greeting" id="greeting"></div>

  <!-- ============ 未ログイン時：ログイン / 新規登録 ============ -->
  <div id="authView" style="display:none;">
    <div class="card">
      <div class="auth-tabs">
        <button class="auth-tab active" id="tabLogin" onclick="switchAuth('login')">ログイン</button>
        <button class="auth-tab" id="tabRegister" onclick="switchAuth('register')">新規登録</button>
      </div>

      <!-- ログイン -->
      <div id="loginForm">
        <div class="field">
          <label for="li_user">ユーザー名（ID）</label>
          <input type="text" id="li_user" autocomplete="username" placeholder="例: yamada_taro">
        </div>
        <div class="field">
          <label for="li_pw">パスワード</label>
          <input type="password" id="li_pw" autocomplete="current-password" placeholder="パスワード">
        </div>
        <div class="btn-row"><button class="btn btn-save btn-block" onclick="doLogin()">ログイン</button></div>
        <div class="err" id="loginErr"></div>
      </div>

      <!-- 新規登録 -->
      <div id="registerForm" style="display:none;">
        <div class="field">
          <label for="rg_name">氏名</label>
          <input type="text" id="rg_name" placeholder="例: 山田 太郎" maxlength="50">
        </div>
        <div class="field">
          <label for="rg_user">ユーザー名（ID）</label>
          <input type="text" id="rg_user" autocomplete="username" placeholder="半角英数字・記号(_ . -) 3〜50文字">
          <div class="hint">ログイン時に使うIDです。後から変更できません。</div>
        </div>
        <div class="field">
          <label for="rg_pw">パスワード</label>
          <input type="password" id="rg_pw" autocomplete="new-password" placeholder="4文字以上">
          <div class="hint">パスワードは暗号化（ハッシュ化）して保存され、元の文字列は保持されません。</div>
        </div>
        <div class="field">
          <label for="rg_area">受験予定自治体</label>
          <select id="rg_area"></select>
        </div>
        <div class="field">
          <label for="rg_school">受験校種</label>
          <select id="rg_school"></select>
        </div>
        <div class="field">
          <label for="rg_subject">受験教科</label>
          <select id="rg_subject"></select>
        </div>
        <div class="btn-row"><button class="btn btn-save btn-block" onclick="doRegister()">登録してはじめる</button></div>
        <div class="err" id="registerErr"></div>
      </div>
    </div>
  </div>

  <!-- ============ ログイン時：プロフィール＋成績 ============ -->
  <div id="dashView" style="display:none;">

    <div class="card">
      <h2>📝 プロフィール</h2>
      <div class="field field-readonly">
        <label for="pf_user">ユーザー名（ID）</label>
        <input type="text" id="pf_user" readonly>
      </div>
      <div class="field">
        <label for="pf_name">氏名</label>
        <input type="text" id="pf_name" maxlength="50">
      </div>
      <div class="field">
        <label for="pf_area">受験予定自治体</label>
        <select id="pf_area"></select>
      </div>
      <div class="field">
        <label for="pf_school">受験校種</label>
        <select id="pf_school"></select>
      </div>
      <div class="field">
        <label for="pf_subject">受験教科</label>
        <select id="pf_subject"></select>
      </div>
      <div class="field">
        <label for="pf_target">1日の目標学習時間（分）</label>
        <input type="number" id="pf_target" min="0" max="1440" step="5" placeholder="例: 60（0で目標ラインなし）">
        <div class="hint">学習時間グラフに目標ラインを表示します（週は×7、月は×30で換算）。</div>
      </div>
      <div class="btn-row">
        <button class="btn btn-save" onclick="saveProfile()">保存</button>
        <button class="btn btn-sub" onclick="togglePw()">パスワード変更</button>
        <button class="btn btn-clear" onclick="doLogout()">ログアウト</button>
      </div>
      <div id="pwBox" style="display:none; margin-top:14px;">
        <div class="field">
          <label for="pf_newpw">新しいパスワード</label>
          <input type="password" id="pf_newpw" autocomplete="new-password" placeholder="4文字以上">
        </div>
        <div class="btn-row"><button class="btn btn-save" onclick="saveNewPw()">パスワードを更新</button></div>
      </div>
    </div>

    <div class="card">
      <h2>⏱ 学習時間</h2>
      <div class="summary-row" id="studySummary"></div>
      <div class="study-tabs">
        <button class="study-tab active" data-range="day" onclick="switchStudy('day')">日</button>
        <button class="study-tab" data-range="week" onclick="switchStudy('week')">週</button>
        <button class="study-tab" data-range="month" onclick="switchStudy('month')">月</button>
      </div>
      <div id="studyChart"></div>
    </div>

    <div class="card">
      <h2>📅 曜日別の傾向</h2>
      <p class="note">直近8週間の、曜日ごとの平均学習時間です。</p>
      <div id="weekdayChart"></div>
    </div>

    <div class="card">
      <h2>🎯 クイズでお手軽演習</h2>
      <div id="quiz5Stats"></div>
    </div>

    <div class="card">
      <h2>💪 実力養成演習</h2>
      <div id="mondaiStats"></div>
    </div>

  </div>
</div>

<div class="toast" id="toast"></div>

<script>window.KYOSAI_TRACK_STUDY = false;</script>
<script src="userstats.js"></script>
<script>
/* ---------- 選択肢データ ---------- */
var AREA_OPTIONS = {
  '都道府県': ['北海道','青森県','岩手県','宮城県','秋田県','山形県','福島県','茨城県','栃木県','群馬県','埼玉県','千葉県','東京都','神奈川県','新潟県','富山県','石川県','福井県','山梨県','長野県','岐阜県','静岡県','愛知県','三重県','滋賀県','京都府','大阪府','兵庫県','奈良県','和歌山県','鳥取県','島根県','岡山県','広島県','山口県','徳島県','香川県','愛媛県','高知県','福岡県','佐賀県','長崎県','熊本県','大分県','宮崎県','鹿児島県','沖縄県'],
  '指定都市': ['札幌市','仙台市','さいたま市','千葉市','横浜市','川崎市','相模原市','新潟市','静岡市','浜松市','名古屋市','京都市','大阪市','堺市','神戸市','岡山市','広島市','北九州市','福岡市','熊本市']
};
var SCHOOL_OPTIONS = ['小学校','中学校','高等学校','特別支援学校','養護教諭','栄養教諭','その他'];
var SUBJECT_OPTIONS = ['全科（小学校）','国語','社会','地理歴史','公民','数学','理科','物理','化学','生物','地学','英語','音楽','美術','工芸','書道','保健体育','技術','家庭','情報','農業','工業','商業','水産','福祉','養護','栄養','その他'];

/* 分野（カテゴリ）の表示順 */
var CATEGORY_ORDER = ['教育原理','学習指導要領','教育史','教育心理','教育法規','教育時事','ローカル問題'];

function fillAreaSelect(sel) {
  sel.innerHTML = '<option value="">― 選択してください ―</option>';
  Object.keys(AREA_OPTIONS).forEach(function (grp) {
    var og = document.createElement('optgroup'); og.label = grp;
    AREA_OPTIONS[grp].forEach(function (v) {
      var o = document.createElement('option'); o.value = v; o.textContent = v; og.appendChild(o);
    });
    sel.appendChild(og);
  });
}
function fillSelect(sel, list) {
  sel.innerHTML = '<option value="">― 選択してください ―</option>';
  list.forEach(function (v) {
    var o = document.createElement('option'); o.value = v; o.textContent = v; sel.appendChild(o);
  });
}

function showToast(msg) {
  var t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(function () { t.classList.remove('show'); }, 2500);
}

/* ---------- 認証画面 ---------- */
function switchAuth(which) {
  var isLogin = which === 'login';
  document.getElementById('tabLogin').classList.toggle('active', isLogin);
  document.getElementById('tabRegister').classList.toggle('active', !isLogin);
  document.getElementById('loginForm').style.display = isLogin ? '' : 'none';
  document.getElementById('registerForm').style.display = isLogin ? 'none' : '';
}

function doLogin() {
  var u = document.getElementById('li_user').value;
  var p = document.getElementById('li_pw').value;
  var errEl = document.getElementById('loginErr');
  errEl.textContent = '';
  KyosaiUser.login(u, p).then(function (r) {
    if (!r.ok) { errEl.textContent = r.error; return; }
    render();
    showToast('ログインしました');
  });
}

function doRegister() {
  var errEl = document.getElementById('registerErr');
  errEl.textContent = '';
  KyosaiUser.register({
    username: document.getElementById('rg_user').value,
    password: document.getElementById('rg_pw').value,
    name: document.getElementById('rg_name').value,
    area: document.getElementById('rg_area').value,
    schoolType: document.getElementById('rg_school').value,
    subject: document.getElementById('rg_subject').value
  }).then(function (r) {
    if (!r.ok) { errEl.textContent = r.error; return; }
    render();
    showToast('登録しました。ようこそ！');
  });
}

/* ---------- プロフィール ---------- */
function saveProfile() {
  KyosaiUser.updateProfile({
    name: document.getElementById('pf_name').value.trim(),
    area: document.getElementById('pf_area').value,
    schoolType: document.getElementById('pf_school').value,
    subject: document.getElementById('pf_subject').value,
    dailyTargetMin: parseInt(document.getElementById('pf_target').value, 10) || 0
  });
  updateGreeting();
  renderStudyChart();
  showToast('保存しました');
}
function togglePw() {
  var box = document.getElementById('pwBox');
  box.style.display = box.style.display === 'none' ? '' : 'none';
}
function saveNewPw() {
  var pw = document.getElementById('pf_newpw').value;
  if (!pw || pw.length < 4) { showToast('パスワードは4文字以上にしてください'); return; }
  KyosaiUser.changePassword(pw).then(function (ok) {
    if (ok) { document.getElementById('pf_newpw').value = ''; document.getElementById('pwBox').style.display = 'none'; showToast('パスワードを更新しました'); }
    else { showToast('更新に失敗しました'); }
  });
}
function doLogout() {
  if (!confirm('ログアウトしますか？')) return;
  KyosaiUser.logout();
  render();
  showToast('ログアウトしました');
}

function updateGreeting() {
  var u = KyosaiUser.getCurrentUser();
  var g = document.getElementById('greeting');
  g.textContent = u ? ('ようこそ、' + (u.name || u.username) + ' さん') : '';
}

/* ---------- 成績ダッシュボード ---------- */
function rateClass(r) { return r == null ? '' : (r >= 70 ? 'rate-good' : (r >= 50 ? 'rate-mid' : 'rate-low')); }
function rateText(b) {
  var r = KyosaiUser.rate(b);
  return r == null ? '―' : '<span class="' + rateClass(r) + '">' + r + '%</span>';
}

function sortedCategoryKeys(map) {
  var keys = Object.keys(map);
  keys.sort(function (a, b) {
    var ia = CATEGORY_ORDER.indexOf(a), ib = CATEGORY_ORDER.indexOf(b);
    if (ia === -1) ia = 99; if (ib === -1) ib = 99;
    if (ia !== ib) return ia - ib;
    return a < b ? -1 : 1;
  });
  return keys;
}

function statTableHtml(map, firstColLabel, keys) {
  if (!keys.length) return '<div class="empty-stat">まだ解答記録がありません。</div>';
  var rows = keys.map(function (k) {
    var b = map[k];
    var r = KyosaiUser.rate(b);
    var bar = r == null ? '' : '<div class="bar-wrap"><div class="bar" style="width:' + r + '%"></div></div>';
    return '<tr><td>' + escapeHtml(k) + bar + '</td>' +
           '<td class="num">' + b.answered + ' 回</td>' +
           '<td class="num">' + rateText(b) + '</td></tr>';
  }).join('');
  return '<table class="stat-table"><thead><tr>' +
         '<th>' + firstColLabel + '</th><th class="num">解答回数</th><th class="num">正答率</th>' +
         '</tr></thead><tbody>' + rows + '</tbody></table>';
}

function summaryHtml(total) {
  var r = KyosaiUser.rate(total);
  return '<div class="summary-row">' +
    '<div class="summary-box"><div class="lbl">総解答数</div><div class="num">' + total.answered + '<small> 回</small></div></div>' +
    '<div class="summary-box"><div class="lbl">正解数</div><div class="num">' + total.correct + '<small> 問</small></div></div>' +
    '<div class="summary-box"><div class="lbl">正答率</div><div class="num">' + (r == null ? '―' : r + '<small>%</small>') + '</div></div>' +
    '</div>';
}

function renderQuiz5Stats() {
  var s = KyosaiUser.getStats('quiz5');
  var el = document.getElementById('quiz5Stats');
  if (!s.total.answered) { el.innerHTML = '<div class="empty-stat">まだ解答記録がありません。<br>「クイズでお手軽演習」を解くとここに集計されます。</div>'; return; }
  var monthKeys = Object.keys(s.byMonth).sort(); // YYYY-MM 昇順
  el.innerHTML = summaryHtml(s.total) +
    '<div class="sub-title">📚 分野別</div>' + statTableHtml(s.byCategory, '分野', sortedCategoryKeys(s.byCategory)) +
    '<div class="sub-title">🗓 月別</div>' + statTableHtml(s.byMonth, '月', monthKeys);
}

function renderMondaiStats() {
  var s = KyosaiUser.getStats('mondai');
  var el = document.getElementById('mondaiStats');
  if (!s.total.answered) { el.innerHTML = '<div class="empty-stat">まだ解答記録がありません。<br>「実力養成演習」を解くとここに集計されます。</div>'; return; }
  el.innerHTML = summaryHtml(s.total) +
    '<div class="sub-title">📚 分野別</div>' + statTableHtml(s.byCategory, '分野', sortedCategoryKeys(s.byCategory));
}

function escapeHtml(s) {
  return String(s == null ? '' : s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

/* ---------- 学習時間 ---------- */
var studyRange = 'day';
function fmtDur(sec) {
  sec = Math.round(sec || 0);
  if (sec <= 0) return '0分';
  if (sec < 3600) return Math.max(1, Math.round(sec / 60)) + '分';
  var h = Math.floor(sec / 3600), m = Math.round((sec % 3600) / 60);
  return h + '時間' + (m ? m + '分' : '');
}
function fmtDurShort(sec) {
  if (!sec || sec <= 0) return '';
  if (sec < 3600) return Math.round(sec / 60) + '分';
  var h = Math.floor(sec / 3600), m = Math.round((sec % 3600) / 60);
  return h + 'h' + (m ? m : '');
}
function barChartSvg(data, targetSec) {
  var max = 0; data.forEach(function (d) { if (d.seconds > max) max = d.seconds; });
  if (targetSec && targetSec > max) max = targetSec;
  if (max <= 0) return '<div class="empty-stat">この期間の学習記録はまだありません。</div>';
  var n = data.length, bw = 34, gap = 9, padL = 8, padR = 8, padT = 22, padB = 24, chartH = 130;
  var W = padL + padR + n * bw + (n - 1) * gap, H = padT + chartH + padB;
  var bars = data.map(function (d, i) {
    var x = padL + i * (bw + gap);
    var h = Math.round((d.seconds / max) * chartH);
    var y = padT + (chartH - h);
    var top = fmtDurShort(d.seconds);
    var s = '<rect x="' + x + '" y="' + y + '" width="' + bw + '" height="' + h + '" rx="4" fill="url(#sbar)"></rect>';
    if (top) s += '<text x="' + (x + bw / 2) + '" y="' + (y - 5) + '" text-anchor="middle" font-size="10" fill="#1e3799">' + top + '</text>';
    s += '<text x="' + (x + bw / 2) + '" y="' + (padT + chartH + 16) + '" text-anchor="middle" font-size="10" fill="#777">' + escapeHtml(d.label) + '</text>';
    return s;
  }).join('');
  var targetLine = '';
  if (targetSec && targetSec > 0) {
    var ty = padT + (chartH - Math.round((targetSec / max) * chartH));
    targetLine =
      '<line x1="' + padL + '" y1="' + ty + '" x2="' + (W - padR) + '" y2="' + ty + '" stroke="#e67e22" stroke-width="1.5" stroke-dasharray="5 4"></line>' +
      '<text x="' + (W - padR) + '" y="' + (ty - 4) + '" text-anchor="end" font-size="10" fill="#e67e22">目標 ' + fmtDurShort(targetSec) + '</text>';
  }
  return '<svg viewBox="0 0 ' + W + ' ' + H + '" width="100%" preserveAspectRatio="xMidYMid meet" style="max-width:100%;height:auto;display:block;">' +
    '<defs><linearGradient id="sbar" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#3a7bd5"/><stop offset="1" stop-color="#1e3799"/></linearGradient></defs>' +
    bars + targetLine + '</svg>';
}
function switchStudy(range) {
  studyRange = range;
  var btns = document.querySelectorAll('.study-tab');
  for (var i = 0; i < btns.length; i++) {
    btns[i].classList.toggle('active', btns[i].getAttribute('data-range') === range);
  }
  renderStudyChart();
}
function renderStudyChart() {
  var targetMin = KyosaiUser.getDailyTargetMin();
  var data, targetSec;
  if (studyRange === 'week') { data = KyosaiUser.getStudyByWeek(8); targetSec = targetMin * 60 * 7; }
  else if (studyRange === 'month') { data = KyosaiUser.getStudyByMonth(6); targetSec = targetMin * 60 * 30; }
  else { data = KyosaiUser.getStudyByDay(14); targetSec = targetMin * 60; }
  document.getElementById('studyChart').innerHTML = barChartSvg(data, targetSec);
}
function renderWeekday() {
  var rows = KyosaiUser.getStudyByWeekday(8).map(function (b) { return { label: b.label, seconds: b.avg }; });
  var total = rows.reduce(function (a, b) { return a + b.seconds; }, 0);
  var el = document.getElementById('weekdayChart');
  if (total <= 0) { el.innerHTML = '<div class="empty-stat">まだ学習記録がありません。</div>'; return; }
  el.innerHTML = barChartSvg(rows, 0);
}
function renderStudy() {
  var total = KyosaiUser.getStudyTotal();
  var days = KyosaiUser.getStudyActiveDays();
  var avg = days ? total / days : 0;
  document.getElementById('studySummary').innerHTML =
    '<div class="summary-box"><div class="lbl">累計学習時間</div><div class="num" style="font-size:1.25em;">' + fmtDur(total) + '</div></div>' +
    '<div class="summary-box"><div class="lbl">学習日数</div><div class="num">' + days + '<small> 日</small></div></div>' +
    '<div class="summary-box"><div class="lbl">1日あたり</div><div class="num" style="font-size:1.25em;">' + fmtDur(avg) + '</div></div>';
  renderStudyChart();
}

/* ---------- 画面切替 ---------- */
function render() {
  var user = KyosaiUser.getCurrentUser();
  updateGreeting();
  if (user) {
    document.getElementById('authView').style.display = 'none';
    document.getElementById('dashView').style.display = '';
    document.getElementById('pf_user').value = user.username;
    document.getElementById('pf_name').value = user.name || '';
    document.getElementById('pf_area').value = user.area || '';
    document.getElementById('pf_school').value = user.schoolType || '';
    document.getElementById('pf_subject').value = user.subject || '';
    renderStudy();
    renderQuiz5Stats();
    renderMondaiStats();
  } else {
    document.getElementById('dashView').style.display = 'none';
    document.getElementById('authView').style.display = '';
    switchAuth('login');
  }
}

/* ---------- 初期化 ---------- */
(function init() {
  fillAreaSelect(document.getElementById('rg_area'));
  fillAreaSelect(document.getElementById('pf_area'));
  fillSelect(document.getElementById('rg_school'), SCHOOL_OPTIONS);
  fillSelect(document.getElementById('pf_school'), SCHOOL_OPTIONS);
  fillSelect(document.getElementById('rg_subject'), SUBJECT_OPTIONS);
  fillSelect(document.getElementById('pf_subject'), SUBJECT_OPTIONS);

  // Enterキーでログイン
  ['li_user', 'li_pw'].forEach(function (id) {
    document.getElementById(id).addEventListener('keydown', function (e) { if (e.key === 'Enter') doLogin(); });
  });

  render();
})();
</script>

